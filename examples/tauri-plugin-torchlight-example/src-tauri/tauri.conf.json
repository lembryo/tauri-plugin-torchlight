{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "tauri-plugin-torchlight-example",
    "version": "1.0.10",
    "identifier": "com.mao.tauri-plugin-torchlight-example",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "tauri-plugin-torchlight-example",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
    }
}
