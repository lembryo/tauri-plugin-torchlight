{
    "name": "tauri-plugin-torchlight-api",
    "version": "1.0.10",
    "author": "mao <mao.lembryo@gmail.com>",
    "description": "JavaScript/TypeScript bindings for tauri-plugin-torchlight: control the smartphone torch (on/off, brightness, availability, state and change events) from Tauri v2 apps.",
    "type": "module",
    "types": "./dist-js/index.d.ts",
    "main": "./dist-js/index.cjs",
    "module": "./dist-js/index.js",
    "exports": {
        "types": "./dist-js/index.d.ts",
        "import": "./dist-js/index.js",
        "require": "./dist-js/index.cjs"
    },
    "files": [
        "dist-js",
        "README.md"
    ],
    "scripts": {
        "build": "rollup -c",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build",
        "pretest": "npm run build"
    },
    "dependencies": {
        "@tauri-apps/api": "2.11.1"
    },
    "devDependencies": {
        "@rollup/plugin-typescript": "12.1.2",
        "license-checker": "25.0.1",
        "prettier": "3.9.4",
        "prettier-plugin-rust": "0.1.9",
        "rollup": "4.52.4",
        "tslib": "2.8.1",
        "typescript": "5.9.3"
    }
}
